                "file_path": "/path/to/file",
                "ignore_control_bucket": false
            },
            "reuse_existing": false
        },
        "eval_ds": {
            "name": "eval_dataset",
            "sample_ratio": 0.2,
            "sample_size_limit": 1000,
            "min_rows": 50,
            "source": "file",
            "source_specs": {
                "start_date": "2024-01-01T00:00:00",
                "end_date": "2024-01-31T23:59:59"
            },
            "reuse_existing": true
        },
        "calibration_ds": {
            "name": "calibration_dataset",
            "sample_size_limit": 500,
            "source": "router_logs",
